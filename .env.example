# ─── Docker Compose Environment ──────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=supersecretpassword
POSTGRES_DB=api_management

# Redis
REDIS_PASSWORD=redispassword

# JWT Secrets — use long random strings in production
# Generate: openssl rand -hex 64
JWT_ACCESS_SECRET=change-me-access-secret-must-be-at-least-32-characters-long!!
JWT_REFRESH_SECRET=change-me-refresh-secret-must-be-at-least-32-characters-long!

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Security
BCRYPT_SALT_ROUNDS=12

# AES-256 encryption key — exactly 32 characters
# Generate: openssl rand -hex 16
ENCRYPTION_KEY=change-me-32-character-key-here!

# CORS — frontend URL(s), comma-separated
CORS_ORIGIN=http://localhost:3000

# Swagger
SWAGGER_ENABLED=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
